{
	"name": "archmac-web",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"description": "Sitio del proyecto ArchMac (web + documentación). La simulación vive en /frontend.",
	"scripts": {
		"dev": "node scripts/dev.mjs",
		"dev:web": "vite",
		"dev:frontend": "pnpm --dir frontend exec vite --base=/frontend/ --port 5173",
		"build": "vite build",
		"build:web": "vite build",
		"build:frontend": "pnpm --dir frontend exec vite build --base=/frontend/ --outDir=../dist/frontend --emptyOutDir",
		"preview": "vite preview",
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"check:frontend": "pnpm --dir frontend check",
		"check:all": "pnpm check && pnpm check:frontend"
	},
	"devDependencies": {
		"@sveltejs/vite-plugin-svelte": "^4.0.0",
		"svelte": "^5.34.0",
		"svelte-check": "^4.2.0",
		"typescript": "^5.8.0",
		"vite": "^5.4.10"
	},
	"pnpm": {
		"onlyBuiltDependencies": ["esbuild"]
	}
}
